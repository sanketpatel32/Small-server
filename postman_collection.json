        },
        {
          "name": "Update public item (PUT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status', () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));",
                  "if (pm.response.code === 200) { pm.test('payload updated', () => pm.expect(pm.response.json().payload.event).to.eql('user.updated')); }"
                ]
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"user.updated\",\n  \"updated\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
