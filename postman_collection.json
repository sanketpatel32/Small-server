          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"status\": \"cleared\",\n  \"scope\": \"public\",\n  \"removed\": 3\n}"
            }
          ]
