          "protocolProfileBehavior": {
            "disableBodyPruning": true
          },
          "request": {
            "method": "GET",
            "header": [],
            "body": null,
            "url": {
              "raw": "http://localhost:8795/public/items/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8795",
              "path": [
                "public",
                "items",
                "1"
              ]
