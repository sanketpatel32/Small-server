              }
            },
            "url": {
              "raw": "http://localhost:8795/public/items/1",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8795",
              "path": [
                "public",
                "items",
                "1"
              ]
            },
            "description": "Replace a public item's payload with any new JSON. Returns the updated item, or 404."
          },
          "response": []
        },
        {
          "name": "Delete public item",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status', () => pm.expect(pm.response.code).to.be.oneOf([200, 404]));",
                  "if (pm.response.code === 200) { pm.test('deleted shape', () => pm.expect(pm.response.json().status).to.eql('deleted')); }"
                ]
              }
            }
          ],
          "protocolProfileBehavior": {
            "disableBodyPruning": true
